# Minimal operator config (preferred)
#
# This file is intentionally small: it contains only secrets + operator intent.
# Most tuning is derived at runtime (wallet snapshot, deployable, zombie pressure, accounting safety).
#
# Backward compatibility: the code still accepts the legacy env vars as overrides if you set them.

# --- Secrets ---
BIRDEYE_API_KEY=replace_me
JUPITER_API_KEY=replace_me

# --- Wallet (required for live mode) ---
SOLANA_KEYPAIR_PATH=./wallets/example/wallet.json

# --- Trading mode ---
DRY_RUN=true
LIVE_TRADING_ENABLED=false
CHAIN=solana

# --- Operator intent ---
BASE_POSITION_SIZE_SOL=0.06
# Optional: conservative | balanced | aggressive
RISK_MODE=balanced
