# --- Required ---
BIRDEYE_API_KEY=replace_me
JUPITER_API_KEY=replace_me

# Preferred wallet credential (live mode)
SOLANA_KEYPAIR_PATH=./wallets/example/wallet.json
# Deprecated fallback (optional)
BS58_PRIVATE_KEY=

# --- Trading mode ---
DRY_RUN=true
LIVE_TRADING_ENABLED=false
CHAIN=solana

# --- Runtime ---
POLL_INTERVAL_SECONDS=90
RUNTIME_DIR=runtime
STATE_PATH=runtime/state.json
JOURNAL_PATH=runtime/journal.jsonl

# --- Discovery ---
DISCOVERY_LIMIT=25
DISCOVERY_MAX_CANDIDATES=8
DISCOVERY_INTERVAL_SECONDS=30
MAX_ACTIVE_CANDIDATES=7
CANDIDATE_CACHE_TTL_SECONDS=120
ROUTE_CHECK_CACHE_TTL_SECONDS=90
PREFILTER_MIN_LIQUIDITY_USD=50000
PREFILTER_MAX_AGE_HOURS=48
PREFILTER_MIN_RECENT_VOLUME_USD=30000
MIN_LIQUIDITY_USD=60000
MIN_EXIT_LIQUIDITY_USD=40000
REQUIRE_BIRDEYE_EXIT_LIQUIDITY=false
MIN_VOLUME_24H_USD=80000
MIN_BUY_SELL_RATIO=1.02
MIN_DISCOVERY_SCORE=44
MAX_TOKEN_AGE_HOURS=72

# --- Early risk bucket (entry only; exits unchanged) ---
# When enabled, discovery may accept some candidates that only fail:
# - reject_bad_buy_sell_ratio
# - reject_low_score
# and open them with a smaller size.
EARLY_RISK_BUCKET_ENABLED=false
EARLY_RISK_POSITION_SIZE_SOL=0.03
EARLY_RISK_MIN_SCORE_FLOOR=0
BLOCK_MUTABLE_MINT=true
BLOCK_FREEZABLE=true
REQUIRE_JUP_SELL_ROUTE=true

# --- Position sizing ---
PORTFOLIO_START_SOL=1.0
MAX_OPEN_POSITIONS=3
# Entry allocation behavior:
# strict = conservative (early-risk only when portfolio nearly empty)
# balanced = standard first, early-risk fills remaining slots (recommended)
# fill_slots = aggressively fill available slots within safety limits
ENTRY_CAPACITY_MODE=strict
BASE_POSITION_SIZE_SOL=0.08
MAX_POSITION_SIZE_SOL=0.12
CASH_RESERVE_SOL=0.30
MIN_ORDER_SIZE_SOL=0.03
MAX_DAILY_NEW_POSITIONS=4
COOLDOWN_MINUTES_AFTER_EXIT=20

# --- Execution ---
DEFAULT_SLIPPAGE_BPS=250
MAX_ACCEPTABLE_PRICE_IMPACT_BPS=700
USE_JUPITER_MANAGED_EXECUTION=true

# --- Risk / ladder ---
STOP_LOSS_PCT=20
TRAILING_STOP_PCT=12
TRAILING_ARM_PCT=25
TIME_STOP_MINUTES=240
TAKE_PROFIT_LEVELS_PCT=25,60,120,250
TAKE_PROFIT_FRACTIONS=0.15,0.2,0.25,0.2
FORCE_FULL_EXIT_ON_LIQUIDITY_BREAK=true
LIQUIDITY_BREAK_RATIO=0.55
EXIT_PROBE_FRACTIONS=0.1,0.2,0.35,0.5,1.0

# --- Hachi mode (preferred modern exit controller) ---
# When enabled, exits are primarily controlled by the Hachi dripper (Jupiter-quote-driven),
# and the legacy TP ladder is bypassed.
HACHI_DRIPPER_ENABLED=false
HACHI_MAX_PRICE_IMPACT_BPS=900

# Hachi brain (defaults from creeper_dripper/config.py)
HACHI_PROFIT_HARVEST_MIN_PCT=5.0
HACHI_NEUTRAL_FLOOR_PCT=-3.0
HACHI_EMERGENCY_PNL_PCT=-12.0
HACHI_WEAKENING_DROP_PCT=4.0
HACHI_COLLAPSE_DROP_PCT=8.0

# --- Drip exit (legacy; optional) ---
# When enabled, eligible exits may be split into sequential chunks with pacing.
DRIP_EXIT_ENABLED=false
DRIP_CHUNK_PCTS=0.10,0.25,0.50
DRIP_NEAR_EQUAL_BAND=0.002
DRIP_MIN_CHUNK_WAIT_SECONDS=30

# --- Logging ---
LOG_LEVEL=INFO

# --- Safety rails ---
DAILY_REALIZED_LOSS_CAP_SOL=1.0
MAX_CONSECUTIVE_EXECUTION_FAILURES=6
STALE_MARKET_DATA_MINUTES=10
UNKNOWN_EXIT_SATURATION_LIMIT=6
MAX_EXIT_BLOCKED_POSITIONS=5
